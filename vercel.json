{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/cron/reminders", "schedule": "45 5 * * *" },
    { "path": "/api/cron/reminders", "schedule": "45 6 * * *" },
    { "path": "/api/cron/reminders", "schedule": "15 17 * * *" },
    { "path": "/api/cron/reminders", "schedule": "15 18 * * *" },
    { "path": "/api/cron/reminders", "schedule": "45 15 * * *" },
    { "path": "/api/cron/reminders", "schedule": "45 16 * * *" },
    { "path": "/api/cron/reminders", "schedule": "15 3 * * *" },
    { "path": "/api/cron/reminders", "schedule": "15 4 * * *" }
  ]
}
