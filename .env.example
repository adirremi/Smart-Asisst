# ─── Frontend (exposed to the browser, must start with VITE_) ────────────────
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# ─── Server-side only (Vercel serverless functions) ──────────────────────────
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Calendar OAuth (from Google Cloud Console → Credentials → OAuth client)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Must exactly match the Authorized redirect URI configured in Google Cloud.
GOOGLE_REDIRECT_URI=https://YOUR_APP.vercel.app/api/auth/google/callback

# Secret used to sign the OAuth "state" parameter (any long random string)
OAUTH_STATE_SECRET=generate-a-long-random-string

# Base URL of the deployed app (used for post-OAuth redirects). Optional on Vercel.
APP_URL=https://YOUR_APP.vercel.app

# ─── Webhooks (Basic Auth credentials for the task/calendar webhooks) ────────
TASK_WEBHOOK_USERNAME=webhook-user
TASK_WEBHOOK_PASSWORD=a-strong-password
# Which user owns rows created via webhook (Supabase → Authentication → Users → user UID)
WEBHOOK_OWNER_USER_ID=
WEBHOOK_OWNER_EMAIL=
