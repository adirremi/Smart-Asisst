# ─── Frontend (exposed to the browser, must start with VITE_) ────────────────
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
VITE_APP_URL=https://YOUR_APP.vercel.app
# Your Gmail — admin bypasses approval and sees /Admin page
VITE_ADMIN_EMAIL=your@gmail.com

# ─── Server-side only (Vercel serverless functions) ──────────────────────────
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
ADMIN_EMAIL=your@gmail.com
APP_URL=https://YOUR_APP.vercel.app

# Google Calendar OAuth (from Google Cloud Console → Credentials → OAuth client)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://YOUR_APP.vercel.app/api/auth/google/callback
OAUTH_STATE_SECRET=generate-a-long-random-string

# ─── WhatsApp notifications (Twilio) ─────────────────────────────────────────
# Sign up at twilio.com → enable WhatsApp Sandbox → connect your phone
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
ADMIN_WHATSAPP_PHONE=whatsapp:+972501234567

# ─── Webhooks (Basic Auth credentials for the task/calendar webhooks) ────────
TASK_WEBHOOK_USERNAME=webhook-user
TASK_WEBHOOK_PASSWORD=a-strong-password
WEBHOOK_OWNER_USER_ID=
WEBHOOK_OWNER_EMAIL=
