# ─── Frontend (exposed to the browser, must start with VITE_) ────────────────
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
VITE_APP_URL=https://YOUR_APP.vercel.app
# Your Gmail — admin skips onboarding (comma-separated for multiple admins)
VITE_ADMIN_EMAIL=adirremi54@gmail.com

# ─── Server-side only (Vercel serverless functions) ──────────────────────────
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
ADMIN_EMAIL=adirremi54@gmail.com
APP_URL=https://YOUR_APP.vercel.app

# Google Calendar OAuth (from Google Cloud Console → Credentials → OAuth client)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://YOUR_APP.vercel.app/api/auth/google/callback
OAUTH_STATE_SECRET=generate-a-long-random-string

# ─── WhatsApp outgoing (message-queue Edge Function) ─────────────────────────
# Must be a JWT from the message_queue Supabase project (uresekvgdiqlssovnsgx):
# Project Settings → API → anon public (or service_role).
# Random strings will fail because the Edge Function has verify_jwt=true.
# Set in Vercel → smart-asisst → Settings → Environment Variables → Production,
# then Redeploy. Server-side only — never use a VITE_ prefix.
MESSAGE_QUEUE_BEARER_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9....message-queue-anon-or-service-role
# Optional override (defaults to the shared message_queue project function)
# MESSAGE_QUEUE_URL=https://uresekvgdiqlssovnsgx.supabase.co/functions/v1/enqueue-message

# Incoming WhatsApp webhook still uses Wasender; optional shared secret below.
WASENDER_API_KEY=your-wasender-api-key
# Your phone in international format: 972501234567 (no + or dashes)
# Also used by the AI WhatsApp assistant to recognize the admin (who skips
# onboarding) and route their messages using the Jerusalem timezone.
ADMIN_WHATSAPP_PHONE=972508576030

# ─── Webhooks (Basic Auth credentials for the task/calendar webhooks) ────────
TASK_WEBHOOK_USERNAME=webhook-user
TASK_WEBHOOK_PASSWORD=a-strong-password
WEBHOOK_OWNER_USER_ID=
WEBHOOK_OWNER_EMAIL=

# ─── AI message classifier (WhatsApp → event/task) ───────────────────────────
# Provider: openai (recommended) or gemini
AI_PROVIDER=openai
# Model override. Defaults: openai=gpt-4.1-mini, gemini=gemini-2.0-flash
AI_MODEL=gpt-4.1-mini
OPENAI_API_KEY=your-openai-api-key
GEMINI_API_KEY=your-gemini-api-key
# Optional shared secret; if set, Wasender webhook requests must include it
# (header x-webhook-secret or ?secret=). Leave blank to disable the check.
WASENDER_WEBHOOK_SECRET=

# ─── Daily reminder cron (/api/cron/reminders) ───────────────────────────────
# Vercel Cron automatically sends this as a Bearer token to protect the endpoint.
# Generate a long random string. Requires a Vercel plan that allows */15 crons.
CRON_SECRET=generate-a-long-random-string
MESSAGE_QUEUE_BEARER_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InVyZXNla3ZnZGlxbHNzb3Zuc2d4Iiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3NDIyNjY1MiwiZXhwIjoyMDg5ODAyNjUyfQ._5rb3rq1oxz8OYKBdaczNUHCqNkB9X_nO0eKnArVNNQ